# HTTPS 종단 — 도메인별로 Let's Encrypt 인증서를 자동 발급/갱신한다.
# WebSocket(STOMP)과 SSE 스트리밍은 Caddy가 자동으로 처리한다.

# 백엔드: studyflow-api.duckdns.org → Spring Boot
{$BACKEND_DOMAIN} {
	reverse_proxy app:8080
}

# 프론트: studyflow1010.duckdns.org → CloudFront로 중계
# (CloudFront는 커스텀 도메인에 ACM 인증서가 필요한데 DuckDNS로는 검증 불가라,
#  Caddy가 예쁜 주소의 HTTPS를 받아 CloudFront 원본으로 프록시한다)
{$FRONTEND_DOMAIN} {
	reverse_proxy https://{$FRONTEND_CDN} {
		header_up Host {$FRONTEND_CDN}
	}
}
