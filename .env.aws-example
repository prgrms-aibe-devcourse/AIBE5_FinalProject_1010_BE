# AWS 멀티 인스턴스 배포용 환경변수 (docker-compose.aws.yml).
# EC2(team-10-*)에서: cp .env.aws-example .env  후 실제 값으로 채우고 `docker compose -f docker-compose.aws.yml up -d`
# ⚠️ 비밀값은 GitHub Secrets로 관리하고 배포 워크플로우가 .env를 생성하게 하는 것을 권장.

# GitHub Actions가 빌드/푸시한 이미지 태그
DOCKER_IMAGE=ghcr.io/<org>/studyflow:latest

# RDS (MySQL)
DB_HOST=team-10-db.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=studyflow
DB_USERNAME=admin
DB_PASSWORD=__set_me__

# ElastiCache (Redis) — 인메모리 상태/WS 릴레이/ShedLock 공유 저장소
REDIS_HOST=team-10-redis.xxxxxx.ng.0001.apn2.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=

# 파일 저장소 (S3)
APP_STORAGE_TYPE=s3
S3_BUCKET=team-10-studyflow-uploads
# CloudFront를 쓰면 그 도메인(https://dxxxx.cloudfront.net), 비우면 S3 가상호스트 URL 사용
S3_PUBLIC_BASE_URL=
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=__set_me__
AWS_SECRET_KEY=__set_me__

# 인증/외부 연동
JWT_SECRET=__set_me__
LIVEKIT_API_KEY=__set_me__
LIVEKIT_API_SECRET=__set_me__
LIVEKIT_URL=wss://__set_me__

# 프론트 도메인(CORS) — 예: https://app.team-10.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
