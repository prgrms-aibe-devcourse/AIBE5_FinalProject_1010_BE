# =====================================================================
# EC2 배포용 환경변수 예시
# - EC2의 ~/studyflow/.env 로 복사해서 실제 값을 채운다. (절대 git 커밋 금지!)
#   cp .env.prod.example .env
# - docker-compose.prod.yml이 이 값들을 컨테이너에 주입한다.
# =====================================================================

# ── 배포 이미지 (GitHub Actions가 push하는 태그) ──────────────────────
DOCKER_IMAGE=ghcr.io/prgrms-aibe-devcourse/aibe5_finalproject_1010_be:latest

# ── 도메인 ────────────────────────────────────────────────────────────
# 백엔드 도메인 (DuckDNS 등) — Caddy가 이 도메인으로 HTTPS 인증서 자동 발급
BACKEND_DOMAIN=studyflow-api.duckdns.org
# 위 도메인의 전체 URL (OAuth redirect-uri 생성에 사용)
BACKEND_URL=https://studyflow-api.duckdns.org
# 프론트 주소 (CloudFront) — CORS 허용 + 소셜 로그인 후 리다이렉트 대상
FRONTEND_URL=https://dxxxxxxxxxxxx.cloudfront.net

# ── DB / Redis ────────────────────────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=                # 강력한 새 비밀번호 (로컬 1234 재사용 금지)
REDIS_PASSWORD=             # 강력한 새 비밀번호

# ── JWT ───────────────────────────────────────────────────────────────
# 반드시 새로 생성! (로컬 값은 git에 노출된 적 있음)
# 생성 예: openssl rand -base64 32
JWT_SECRET=

# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── 소셜 로그인 (각 개발자 콘솔에서 발급) ─────────────────────────────
# 각 콘솔에 redirect URI 추가 필요: ${BACKEND_URL}/login/oauth2/code/{kakao|google|naver}
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── AWS S3 (파일 업로드 — 현재는 로컬 디스크 저장이라 미사용, 추후 S3 전환 시) ──
S3_BUCKET=studyflow-uploads
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ── LiveKit (화상 수업) ───────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-url
