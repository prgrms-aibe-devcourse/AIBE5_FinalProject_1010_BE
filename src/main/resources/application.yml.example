spring:
  # 비밀 값(OpenAI 키 등)은 application-secret.yml 에서 불러온다. (git 미커밋, optional)
  config:
    import: "optional:classpath:application-secret.yml"
  # Spring AI(OpenAI) 설정. AI 질문 호출은 Spring AI ChatClient로 처리한다.
  # ⚠️ spring-ai 종속성이 있으면 기동 시 API 키가 필요하다.
  #    application-secret.yml 에 spring.ai.openai.api-key 를 반드시 설정할 것
  #    (또는 환경변수 SPRING_AI_OPENAI_API_KEY). 없으면 앱이 기동되지 않는다.
  ai:
    openai:
      chat:
        options:
          model: gpt-4o-mini      # 저렴하고 충분한 성능. 필요 시 gpt-4o 등으로 교체
  datasource:
    url: jdbc:mysql://localhost:3306/studyflow?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

jwt:
  secret: ${JWT_SECRET}
  access-token-expiration: 3600000
  refresh-token-expiration: 604800000

cloud:
  aws:
    s3:
      bucket: ${S3_BUCKET}
    region:
      static: ap-northeast-2
    credentials:
      access-key: ${AWS_ACCESS_KEY}
      secret-key: ${AWS_SECRET_KEY}

livekit:
  api-key: ${LIVEKIT_API_KEY}
  api-secret: ${LIVEKIT_API_SECRET}
  url: ${LIVEKIT_URL}

# OpenAI 키는 application-secret.yml 에 작성한다(아래 예시).
#   spring:
#     ai:
#       openai:
#         api-key: sk-...        # ← 실제 키. 이 값이 없으면 앱이 기동되지 않음
# (모델/엔드포인트 등 그 외 설정은 위 spring.ai.openai 블록에서 관리)

server:
  port: 8080
