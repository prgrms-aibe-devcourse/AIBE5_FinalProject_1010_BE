spring:
  application:
    name: studyflow
  jackson:
    parser:
      strict-duplicate-detection: true
  # 비밀 값(OpenAI 키 등)은 application-secret.yml 에서 불러온다. (git 미커밋, optional)
  config:
    import: "optional:classpath:application-secret.yml"
  datasource:
    # 멀티 인스턴스 배포에서는 DB가 RDS(컨테이너 밖). 호스트/포트/DB명을 환경변수로 외부화한다.
    # (로컬은 기본값 localhost:3306/studyflow 그대로 동작)
    url: jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:studyflow}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect
  data:
    redis:
      # 멀티 인스턴스 배포에서는 Redis가 ElastiCache(컨테이너 밖). 호스트/포트를 환경변수로 외부화한다.
      # 인메모리 상태(화이트보드/오디오/판서권한), WS 브로드캐스트 릴레이, ShedLock이 이 Redis를 공유한다.
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}    # 로컬 무인증 Redis는 빈 값으로 두면 됨
  # Spring AI(OpenAI) 설정. AI 질문 호출은 Spring AI ChatClient로 처리한다.
  # ⚠️ spring-ai 종속성이 있으면 기동 시 API 키가 필요하다.
  #    application-secret.yml 에 spring.ai.openai.api-key 를 반드시 설정할 것
  #    (또는 환경변수 SPRING_AI_OPENAI_API_KEY). 없으면 앱이 기동되지 않는다.
  ai:
    openai:
      chat:
        options:
          model: gpt-4o-mini
  security:
    oauth2:
      client:
        registration:
          kakao:
            client-id: ${KAKAO_CLIENT_ID}
            client-secret: ${KAKAO_CLIENT_SECRET}
            client-authentication-method: client_secret_post
            authorization-grant-type: authorization_code
            redirect-uri: http://localhost:8080/login/oauth2/code/kakao
            scope:
              - profile_nickname
              - profile_image
              - account_email
            client-name: Kakao
          google:
            client-id: ${GOOGLE_CLIENT_ID}
            client-secret: ${GOOGLE_CLIENT_SECRET}
            client-authentication-method: client_secret_basic
            authorization-grant-type: authorization_code
            redirect-uri: http://localhost:8080/login/oauth2/code/google
            scope:
              - profile
              - email
            client-name: Google
          naver:
            client-id: ${NAVER_CLIENT_ID}
            client-secret: ${NAVER_CLIENT_SECRET}
            client-authentication-method: client_secret_basic
            authorization-grant-type: authorization_code
            redirect-uri: http://localhost:8080/login/oauth2/code/naver
            scope:
              - name
              - email
              - nickname
              - profile_image
              - gender
              - birthday
              - age
              - birthyear
              - mobile
            client-name: Naver
        provider:
          kakao:
            authorization-uri: https://kauth.kakao.com/oauth/authorize
            token-uri: https://kauth.kakao.com/oauth/token
            user-info-uri: https://kapi.kakao.com/v2/user/me
            user-name-attribute: id
          google:
            authorization-uri: https://accounts.google.com/o/oauth2/v2/auth
            token-uri: https://www.googleapis.com/oauth2/v4/token
            user-info-uri: https://www.googleapis.com/oauth2/v3/userinfo
            user-name-attribute: sub
          naver:
            authorization-uri: https://nid.naver.com/oauth2.0/authorize
            token-uri: https://nid.naver.com/oauth2.0/token
            user-info-uri: https://openapi.naver.com/v1/nid/me
            user-name-attribute: response
  # 이메일 인증 코드 발송용 SMTP 설정.
  # ⚠️ spring.mail.host 가 없으면 JavaMailSender 빈이 생성되지 않아 기동 시 NoSuchBeanDefinitionException 발생.
  #    application-secret.yml 에 아래 항목을 반드시 설정할 것 (또는 환경변수로 주입).
  #    Gmail 사용 시 구글 계정 → 보안 → 앱 비밀번호에서 발급한 16자리 비밀번호를 password 에 입력.
  mail:
    host: smtp.gmail.com
    port: 587
    username: ${MAIL_USERNAME}
    password: ${MAIL_PASSWORD}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

jwt:
  secret: ${JWT_SECRET}
  access-token-expiration: 600000       # 10분
  refresh-token-expiration: 604800000   # 7일

# 업로드 파일 저장소 선택. local(개발, 디스크) / s3(운영, 멀티 인스턴스).
# 멀티 인스턴스(EC2 2대)에서는 인스턴스 로컬 디스크 저장 시 다른 인스턴스가 파일을 못 읽으므로 s3로 둘 것.
app:
  storage:
    type: ${APP_STORAGE_TYPE:local}

cloud:
  aws:
    s3:
      bucket: ${S3_BUCKET}
      # 브라우저가 직접 받는 공개 URL의 베이스. CloudFront를 쓰면 그 도메인, 비우면 S3 가상호스트 URL 사용.
      public-base-url: ${S3_PUBLIC_BASE_URL:}
    region:
      static: ${AWS_REGION:ap-northeast-2}
    credentials:
      access-key: ${AWS_ACCESS_KEY}
      secret-key: ${AWS_SECRET_KEY}

livekit:
  api-key: ${LIVEKIT_API_KEY}
  api-secret: ${LIVEKIT_API_SECRET}
  url: ${LIVEKIT_URL}

server:
  port: 8080

cors:
  # 배포에서는 프론트 도메인(예: https://app.team-10.example.com)을 환경변수로 주입.
  allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:5173}

# 토스페이먼츠(결제). client-key=프론트 결제창, secret-key=백엔드 승인(노출 금지).
# 공개 테스트 키로 시연 가능. 운영은 실제 상점 키를 환경변수로 주입.
toss:
  client-key: ${TOSS_CLIENT_KEY:test_ck_docs_Ovk5rk1EwkEbP0W43n07xlzm}
  secret-key: ${TOSS_SECRET_KEY:}
  confirm-url: ${TOSS_CONFIRM_URL:https://api.tosspayments.com/v1/payments/confirm}

# OpenAI 키는 application-secret.yml 에 작성한다(아래 예시).
#   spring:
#     ai:
#       openai:
#         api-key: sk-...        # ← 실제 키. 이 값이 없으면 앱이 기동되지 않음
# (모델/엔드포인트 등 그 외 설정은 위 spring.ai.openai 블록에서 관리)
